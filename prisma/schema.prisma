// Prisma Schema for POS-SATHI College Canteen System
// Production-grade with proper indexing, soft deletes, and audit trails

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─── USER & AUTH ───────────────────────────────────────────────

enum Role {
  ADMIN
  CASHIER
  KITCHEN
  INVENTORY_MANAGER
  STUDENT
}

model User {
  id            String    @id @default(uuid())
  email         String    @unique
  username      String    @unique
  passwordHash  String    @map("password_hash")
  firstName     String    @map("first_name")
  lastName      String    @map("last_name")
  role          Role      @default(STUDENT)
  phone         String?
  avatar        String?
  isActive      Boolean   @default(true) @map("is_active")
  lastLoginAt   DateTime? @map("last_login_at")
  createdAt     DateTime  @default(now()) @map("created_at")
  updatedAt     DateTime  @updatedAt @map("updated_at")
  deletedAt     DateTime? @map("deleted_at")

  // Relations
  orders        Order[]   @relation("CashierOrders")
  auditLogs     AuditLog[]
  sessions      Session[]
  walletTransactions WalletTransaction[]

  @@index([role])
  @@index([email])
  @@index([isActive])
  @@map("users")
}

model Session {
  id          String   @id @default(uuid())
  userId      String   @map("user_id")
  token       String   @unique
  expiresAt   DateTime @map("expires_at")
  ipAddress   String?  @map("ip_address")
  userAgent   String?  @map("user_agent")
  createdAt   DateTime @default(now()) @map("created_at")

  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([token])
  @@map("sessions")
}

// ─── MENU & CATEGORIES ────────────────────────────────────────

model Category {
  id          String     @id @default(uuid())
  name        String     @unique
  slug        String     @unique
  description String?
  icon        String?
  sortOrder   Int        @default(0) @map("sort_order")
  isActive    Boolean    @default(true) @map("is_active")
  createdAt   DateTime   @default(now()) @map("created_at")
  updatedAt   DateTime   @updatedAt @map("updated_at")
  deletedAt   DateTime?  @map("deleted_at")

  menuItems   MenuItem[]

  @@index([isActive])
  @@map("categories")
}

model MenuItem {
  id              String          @id @default(uuid())
  name            String
  slug            String          @unique
  description     String?
  categoryId      String          @map("category_id")
  basePrice       Decimal         @map("base_price") @db.Decimal(10, 2)
  taxRate         Decimal         @default(0) @map("tax_rate") @db.Decimal(5, 2)
  image           String?
  isVeg           Boolean         @default(true) @map("is_veg")
  isAvailable     Boolean         @default(true) @map("is_available")
  prepTime        Int             @default(10) @map("prep_time") // minutes
  sortOrder       Int             @default(0) @map("sort_order")
  
  // Time-based availability
  availableFrom   String?         @map("available_from") // HH:MM format
  availableTo     String?         @map("available_to")   // HH:MM format
  availableDays   String?         @map("available_days")  // comma-separated: "MON,TUE,WED"

  createdAt       DateTime        @default(now()) @map("created_at")
  updatedAt       DateTime        @updatedAt @map("updated_at")
  deletedAt       DateTime?       @map("deleted_at")

  // Relations
  category        Category        @relation(fields: [categoryId], references: [id])
  variants        MenuVariant[]
  orderItems      OrderItem[]
  ingredients     MenuIngredient[]
  comboItems      ComboItem[]

  @@index([categoryId])
  @@index([isAvailable])
  @@index([slug])
  @@map("menu_items")
}

model MenuVariant {
  id          String     @id @default(uuid())
  menuItemId  String     @map("menu_item_id")
  name        String     // "Small", "Medium", "Large"
  priceAddon  Decimal    @default(0) @map("price_addon") @db.Decimal(10, 2)
  isAvailable Boolean    @default(true) @map("is_available")
  createdAt   DateTime   @default(now()) @map("created_at")
  updatedAt   DateTime   @updatedAt @map("updated_at")

  menuItem    MenuItem   @relation(fields: [menuItemId], references: [id], onDelete: Cascade)
  orderItems  OrderItem[]

  @@index([menuItemId])
  @@map("menu_variants")
}

model Combo {
  id          String      @id @default(uuid())
  name        String
  slug        String      @unique
  description String?
  price       Decimal     @db.Decimal(10, 2)
  image       String?
  isActive    Boolean     @default(true) @map("is_active")
  createdAt   DateTime    @default(now()) @map("created_at")
  updatedAt   DateTime    @updatedAt @map("updated_at")
  deletedAt   DateTime?   @map("deleted_at")

  comboItems  ComboItem[]

  @@map("combos")
}

model ComboItem {
  id         String   @id @default(uuid())
  comboId    String   @map("combo_id")
  menuItemId String   @map("menu_item_id")
  quantity   Int      @default(1)

  combo      Combo    @relation(fields: [comboId], references: [id], onDelete: Cascade)
  menuItem   MenuItem @relation(fields: [menuItemId], references: [id])

  @@unique([comboId, menuItemId])
  @@map("combo_items")
}

// ─── ORDERS & BILLING ─────────────────────────────────────────

enum OrderStatus {
  PENDING
  PENDING_PAYMENT    // waiting for online payment
  CONFIRMED
  PREPARING
  READY
  SERVED
  CANCELLED
  ON_HOLD
}

enum PaymentMethod {
  CASH
  UPI
  CARD
  NET_BANKING
  WALLET
  ONLINE            // generic online via gateway
  SPLIT
}

enum PaymentStatus {
  PENDING
  INITIATED         // session created with gateway
  COMPLETED
  FAILED
  REFUNDED
  PARTIALLY_REFUNDED
}

enum PaymentGateway {
  NONE
  CASHFREE
  RAZORPAY
  STRIPE
}

model Order {
  id              String         @id @default(uuid())
  orderNumber     String         @unique @map("order_number")
  tokenNumber     Int            @map("token_number")
  cashierId       String?        @map("cashier_id")
  customerName    String?        @map("customer_name")
  customerPhone   String?        @map("customer_phone")
  customerEmail   String?        @map("customer_email")
  status          OrderStatus    @default(PENDING)
  
  // Financial
  subtotal        Decimal        @db.Decimal(10, 2)
  taxAmount       Decimal        @default(0) @map("tax_amount") @db.Decimal(10, 2)
  discountAmount  Decimal        @default(0) @map("discount_amount") @db.Decimal(10, 2)
  totalAmount     Decimal        @map("total_amount") @db.Decimal(10, 2)
  
  // Discount info
  discountType    String?        @map("discount_type") // FLAT, PERCENTAGE, COUPON
  discountValue   Decimal?       @map("discount_value") @db.Decimal(10, 2)
  couponCode      String?        @map("coupon_code")

  // Payment
  paymentMethod   PaymentMethod  @default(CASH) @map("payment_method")
  paymentStatus   PaymentStatus  @default(PENDING) @map("payment_status")
  
  // Meta
  notes           String?
  cancelReason    String?        @map("cancel_reason")
  isPriority      Boolean        @default(false) @map("is_priority")
  counterNumber   Int?           @map("counter_number")
  orderSource     String         @default("POS") @map("order_source") // POS, STUDENT_APP, QR
  
  // Timestamps
  orderedAt       DateTime       @default(now()) @map("ordered_at")
  prepStartedAt   DateTime?      @map("prep_started_at")
  readyAt         DateTime?      @map("ready_at")
  servedAt        DateTime?      @map("served_at")
  cancelledAt     DateTime?      @map("cancelled_at")
  createdAt       DateTime       @default(now()) @map("created_at")
  updatedAt       DateTime       @updatedAt @map("updated_at")

  // Relations
  cashier         User?          @relation("CashierOrders", fields: [cashierId], references: [id])
  items           OrderItem[]
  payments        Payment[]

  @@index([status])
  @@index([cashierId])
  @@index([orderNumber])
  @@index([orderedAt])
  @@index([paymentStatus])
  @@index([tokenNumber])
  @@index([orderSource])
  @@map("orders")
}

model OrderItem {
  id          String       @id @default(uuid())
  orderId     String       @map("order_id")
  menuItemId  String       @map("menu_item_id")
  variantId   String?      @map("variant_id")
  quantity    Int
  unitPrice   Decimal      @map("unit_price") @db.Decimal(10, 2)
  totalPrice  Decimal      @map("total_price") @db.Decimal(10, 2)
  notes       String?
  createdAt   DateTime     @default(now()) @map("created_at")

  order       Order        @relation(fields: [orderId], references: [id], onDelete: Cascade)
  menuItem    MenuItem     @relation(fields: [menuItemId], references: [id])
  variant     MenuVariant? @relation(fields: [variantId], references: [id])

  @@index([orderId])
  @@index([menuItemId])
  @@map("order_items")
}

model Payment {
  id                  String         @id @default(uuid())
  orderId             String         @map("order_id")
  
  // Gateway info
  gateway             PaymentGateway @default(NONE)
  gatewayOrderId      String?        @unique @map("gateway_order_id")     // Cashfree cf_order_id
  paymentSessionId    String?        @map("payment_session_id")           // Cashfree session
  paymentLink         String?        @map("payment_link")
  
  // Payment details
  method              PaymentMethod
  amount              Decimal        @db.Decimal(10, 2)
  currency            String         @default("INR")
  status              PaymentStatus  @default(PENDING)
  
  // Transaction info (from webhook)
  transactionId       String?        @unique @map("transaction_id")       // CF payment_id
  bankReference       String?        @map("bank_reference")
  paymentMethodDetail String?        @map("payment_method_detail")        // "upi", "card", etc.
  
  // Idempotency & Security
  idempotencyKey      String?        @unique @map("idempotency_key")
  webhookVerified     Boolean        @default(false) @map("webhook_verified")
  amountVerified      Boolean        @default(false) @map("amount_verified")
  
  // Refund tracking
  refundId            String?        @map("refund_id")
  refundAmount        Decimal?       @map("refund_amount") @db.Decimal(10, 2)
  refundStatus        String?        @map("refund_status")
  refundedAt          DateTime?      @map("refunded_at")
  
  // Raw data from gateway
  gatewayResponse     Json?          @map("gateway_response")
  webhookPayload      Json?          @map("webhook_payload")
  
  // Error tracking
  failureReason       String?        @map("failure_reason")
  errorCode           String?        @map("error_code")
  
  // Meta
  metadata            Json?
  createdAt           DateTime       @default(now()) @map("created_at")
  updatedAt           DateTime       @updatedAt @map("updated_at")

  order               Order          @relation(fields: [orderId], references: [id], onDelete: Cascade)

  @@index([orderId])
  @@index([status])
  @@index([gateway])
  @@index([gatewayOrderId])
  @@index([transactionId])
  @@index([createdAt])
  @@map("payments")
}

// ─── PAYMENT WEBHOOK EVENT LOG ─────────────────────────────────

model PaymentWebhookLog {
  id              String   @id @default(uuid())
  gateway         String
  eventType       String   @map("event_type")
  orderId         String?  @map("order_id")
  gatewayOrderId  String?  @map("gateway_order_id")
  payload         Json
  signatureValid  Boolean  @map("signature_valid")
  processed       Boolean  @default(false)
  processedAt     DateTime? @map("processed_at")
  error           String?
  createdAt       DateTime @default(now()) @map("created_at")

  @@index([gateway])
  @@index([gatewayOrderId])
  @@index([createdAt])
  @@index([processed])
  @@map("payment_webhook_logs")
}

// ─── INVENTORY ─────────────────────────────────────────────────

model InventoryItem {
  id              String            @id @default(uuid())
  name            String
  unit            String            // kg, liters, pieces, etc.
  currentStock    Decimal           @map("current_stock") @db.Decimal(10, 3)
  minStock        Decimal           @default(0) @map("min_stock") @db.Decimal(10, 3)
  maxStock        Decimal?          @map("max_stock") @db.Decimal(10, 3)
  costPerUnit     Decimal           @map("cost_per_unit") @db.Decimal(10, 2)
  isActive        Boolean           @default(true) @map("is_active")
  createdAt       DateTime          @default(now()) @map("created_at")
  updatedAt       DateTime          @updatedAt @map("updated_at")
  deletedAt       DateTime?         @map("deleted_at")

  // Relations
  menuIngredients MenuIngredient[]
  purchases       PurchaseItem[]
  stockMovements  StockMovement[]
  wastageRecords  WastageRecord[]

  @@index([name])
  @@index([isActive])
  @@map("inventory_items")
}

model MenuIngredient {
  id              String        @id @default(uuid())
  menuItemId      String        @map("menu_item_id")
  inventoryItemId String        @map("inventory_item_id")
  quantityNeeded  Decimal       @map("quantity_needed") @db.Decimal(10, 3)

  menuItem        MenuItem      @relation(fields: [menuItemId], references: [id], onDelete: Cascade)
  inventoryItem   InventoryItem @relation(fields: [inventoryItemId], references: [id])

  @@unique([menuItemId, inventoryItemId])
  @@map("menu_ingredients")
}

model Vendor {
  id          String     @id @default(uuid())
  name        String
  contact     String?
  email       String?
  phone       String?
  address     String?
  gstNumber   String?    @map("gst_number")
  isActive    Boolean    @default(true) @map("is_active")
  createdAt   DateTime   @default(now()) @map("created_at")
  updatedAt   DateTime   @updatedAt @map("updated_at")
  deletedAt   DateTime?  @map("deleted_at")

  purchases   Purchase[]

  @@map("vendors")
}

model Purchase {
  id          String         @id @default(uuid())
  vendorId    String         @map("vendor_id")
  invoiceNo   String?        @map("invoice_no")
  totalAmount Decimal        @map("total_amount") @db.Decimal(10, 2)
  notes       String?
  purchasedAt DateTime       @default(now()) @map("purchased_at")
  createdAt   DateTime       @default(now()) @map("created_at")
  updatedAt   DateTime       @updatedAt @map("updated_at")

  vendor      Vendor         @relation(fields: [vendorId], references: [id])
  items       PurchaseItem[]

  @@index([vendorId])
  @@map("purchases")
}

model PurchaseItem {
  id              String        @id @default(uuid())
  purchaseId      String        @map("purchase_id")
  inventoryItemId String        @map("inventory_item_id")
  quantity        Decimal       @db.Decimal(10, 3)
  unitPrice       Decimal       @map("unit_price") @db.Decimal(10, 2)
  totalPrice      Decimal       @map("total_price") @db.Decimal(10, 2)

  purchase        Purchase      @relation(fields: [purchaseId], references: [id], onDelete: Cascade)
  inventoryItem   InventoryItem @relation(fields: [inventoryItemId], references: [id])

  @@index([purchaseId])
  @@map("purchase_items")
}

model StockMovement {
  id              String        @id @default(uuid())
  inventoryItemId String        @map("inventory_item_id")
  type            String        // IN, OUT, ADJUSTMENT, WASTAGE
  quantity        Decimal       @db.Decimal(10, 3)
  reason          String?
  referenceId     String?       @map("reference_id") // orderId or purchaseId
  createdAt       DateTime      @default(now()) @map("created_at")

  inventoryItem   InventoryItem @relation(fields: [inventoryItemId], references: [id])

  @@index([inventoryItemId])
  @@index([type])
  @@index([createdAt])
  @@map("stock_movements")
}

model WastageRecord {
  id              String        @id @default(uuid())
  inventoryItemId String        @map("inventory_item_id")
  quantity        Decimal       @db.Decimal(10, 3)
  reason          String
  recordedBy      String        @map("recorded_by")
  createdAt       DateTime      @default(now()) @map("created_at")

  inventoryItem   InventoryItem @relation(fields: [inventoryItemId], references: [id])

  @@index([inventoryItemId])
  @@map("wastage_records")
}

// ─── COUPONS & DISCOUNTS ──────────────────────────────────────

model Coupon {
  id            String    @id @default(uuid())
  code          String    @unique
  description   String?
  discountType  String    @map("discount_type") // FLAT, PERCENTAGE
  discountValue Decimal   @map("discount_value") @db.Decimal(10, 2)
  minOrder      Decimal?  @map("min_order") @db.Decimal(10, 2)
  maxDiscount   Decimal?  @map("max_discount") @db.Decimal(10, 2)
  usageLimit    Int?      @map("usage_limit")
  usedCount     Int       @default(0) @map("used_count")
  isActive      Boolean   @default(true) @map("is_active")
  validFrom     DateTime  @map("valid_from")
  validTo       DateTime  @map("valid_to")
  createdAt     DateTime  @default(now()) @map("created_at")
  updatedAt     DateTime  @updatedAt @map("updated_at")

  @@index([code])
  @@index([isActive])
  @@map("coupons")
}

// ─── STUDENT WALLET ───────────────────────────────────────────

model Wallet {
  id          String              @id @default(uuid())
  userId      String              @unique @map("user_id")
  balance     Decimal             @default(0) @db.Decimal(10, 2)
  isActive    Boolean             @default(true) @map("is_active")
  createdAt   DateTime            @default(now()) @map("created_at")
  updatedAt   DateTime            @updatedAt @map("updated_at")

  transactions WalletTransaction[]

  @@map("wallets")
}

model WalletTransaction {
  id          String   @id @default(uuid())
  walletId    String   @map("wallet_id")
  userId      String   @map("user_id")
  type        String   // CREDIT, DEBIT
  amount      Decimal  @db.Decimal(10, 2)
  description String?
  referenceId String?  @map("reference_id")
  createdAt   DateTime @default(now()) @map("created_at")

  wallet      Wallet   @relation(fields: [walletId], references: [id])
  user        User     @relation(fields: [userId], references: [id])

  @@index([walletId])
  @@index([userId])
  @@map("wallet_transactions")
}

// ─── SYSTEM & AUDIT ───────────────────────────────────────────

model AuditLog {
  id          String   @id @default(uuid())
  userId      String?  @map("user_id")
  action      String
  entity      String
  entityId    String?  @map("entity_id")
  oldValue    Json?    @map("old_value")
  newValue    Json?    @map("new_value")
  ipAddress   String?  @map("ip_address")
  userAgent   String?  @map("user_agent")
  createdAt   DateTime @default(now()) @map("created_at")

  user        User?    @relation(fields: [userId], references: [id])

  @@index([userId])
  @@index([entity])
  @@index([action])
  @@index([createdAt])
  @@map("audit_logs")
}

model SystemSetting {
  id        String   @id @default(uuid())
  key       String   @unique
  value     String
  type      String   @default("string") // string, number, boolean, json
  group     String   @default("general")
  label     String?
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@index([key])
  @@index([group])
  @@map("system_settings")
}
